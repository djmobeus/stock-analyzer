# Copy to .env and fill in values. Never commit .env.

# === Required for cloud (Supabase) ===
DATABASE_URL=

# === Email morning digest (Gmail example) ===
# Create a Google App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your@gmail.com
EMAIL_TO=you@p-mouzakis.com

# === Optional: Anthropic Haiku morning prose (~£3-5/mo) ===
ANTHROPIC_API_KEY=

# === Optional: Streamlit app password (also add to Streamlit Cloud secrets) ===
# APP_PASSWORD=choose-a-strong-password

# === Optional ===
# FINNHUB_API_KEY=
# SUPABASE_URL=
# SUPABASE_KEY=
