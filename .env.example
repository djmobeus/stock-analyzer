# Copy to .env and fill in values. Never commit .env.

# Database — leave empty for local SQLite (data/stock_analyzer.db)
# For cloud: postgresql://user:pass@host:5432/dbname (Supabase)
DATABASE_URL=

# Finnhub free API key — https://finnhub.io/register
FINNHUB_API_KEY=your_key_here

# Optional: Anthropic API for morning prose summaries (~£3-5/mo)
# Leave empty to use free template-based briefings
ANTHROPIC_API_KEY=

# Optional: Supabase (if using cloud PostgreSQL)
# SUPABASE_URL=
# SUPABASE_KEY=
